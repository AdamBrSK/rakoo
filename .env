# Database credentials
POSTGRES_USER=rakoo_user
POSTGRES_PASSWORD=rakoo_password
POSTGRES_DB=rakoo_db

# Database connection (for backend)
DATABASE_URL=postgresql://rakoo_user:rakoo_password@db:5432/rakoo_db

# JWT Secret (change this to something random!)
JWT_SECRET_KEY=rakoo_super_secret_key_change_this_later

# Backend port
BACKEND_PORT=5001

# Frontend port
FRONTEND_PORT=3001

# Flask settings
FLASK_ENV=development
FLASK_APP=app.py

# AWS settings (for later when you deploy)
AWS_ACCESS_KEY_ID=your_aws_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_here
AWS_REGION=us-east-1
S3_BUCKET=rakoo-deepfake-bucket

# Azure settings (for later when you deploy)
AZURE_ENDPOINT=https://your-azure-endpoint.azure.com/score
AZURE_KEY=your-azure-key-here
